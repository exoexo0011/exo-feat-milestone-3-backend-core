# EXO backend configuration (copy to .env and adjust)
EXO_ENV=development
EXO_HOST=127.0.0.1
EXO_PORT=8000
EXO_DB_PATH=../database/exo.db
EXO_LOG_LEVEL=INFO
EXO_LOG_DIR=../logs
EXO_CORS_ORIGINS=["http://localhost:5173"]

# AI providers (Phase 1 ships with a local echo provider; keys are optional)
# Provider name must be one registered with ProviderFactory: echo | openai | anthropic
EXO_AI_PROVIDER=echo
# Optional generation defaults (each provider supplies its own default model)
# EXO_AI_MODEL=
EXO_AI_TEMPERATURE=0.7
EXO_AI_MAX_TOKENS=1024
EXO_AI_REQUEST_TIMEOUT=60

# OpenAI (used when EXO_AI_PROVIDER=openai)
# OPENAI_API_KEY=
# EXO_OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (used when EXO_AI_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=
# EXO_ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# EXO_ANTHROPIC_VERSION=2023-06-01
